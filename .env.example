# ==========================================
# Application Config
# ==========================================
APP_ENV=development
APP_LOG_LEVEL=info
SYNC_DAEMON_MODE=true
SYNC_INTERVAL=1h
SYNC_MIN_USERS=1
METRICS_ENABLED=false
METRICS_PORT=8081
METRICS_PUSHGATEWAY_URL=http://localhost:9091
ALERT_RULES_FILE=alert.rules

# ==========================================
# LDAP Configuration (OpenLDAP)
# ==========================================
LDAP_ORGANISATION="Your Org"
LDAP_DOMAIN=example.org
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_PASSWORD=your_ldap_bind_password
LDAP_BASE_DN=dc=example,dc=org
LDAP_SKIP_VERIFY=false

# LDAP Dynamic Query & Mapping
LDAP_ACTIVE_USER=(userPassword=*)
LDAP_FILTER="(&(objectClass=inetOrgPerson)(|(memberOf=cn=app_admin,ou=groups,dc=example,dc=org)(memberOf=cn=app_user,ou=groups,dc=example,dc=org)(memberOf=cn=app_readonly,ou=groups,dc=example,dc=org))({LDAP_ACTIVE_USER}))"
LDAP_MAP_UID=uid
LDAP_MAP_USERNAME=cn
LDAP_MAP_EMAIL=mail

# ==========================================
# phpLDAPadmin Config
# ==========================================
PHPLDAPADMIN_LDAP_HOSTS=ldap
PHPLDAPADMIN_HTTPS=false

# ==========================================
# Elastic Stack Official Configuration
# ==========================================
ELASTIC_PASSWORD=your_elastic_system_password
KIBANA_SYSTEM_PASSWORD=${ELASTIC_PASSWORD}
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ==========================================
# Elasticsearch & Kibana Connection (Go Application)
# ==========================================
ES_ADDRESSES=http://localhost:9200
ES_USERNAME=elastic
ES_INDEX_NAME=users
ES_EXCLUDED_USERS=elastic,kibana_system,logstash_system,beats_system,apm_system,fleet_server_system
ES_MAX_RESULTS=1000
SYNC_SECURITY_USERS=false
