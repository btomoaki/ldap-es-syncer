# ==========================================
# Application Config
# ==========================================
APP_ENV=development
LOG_LEVEL=info

# ==========================================
# Elastic stack official environment variables
# ==========================================
ELASTIC_PASSWORD=adminpassword
KIBANA_SYSTEM_PASSWORD=${ELASTIC_PASSWORD}

# ==========================================
# LDAP Configuration
# ==========================================
LDAP_ORGANISATION=Example Org
LDAP_DOMAIN=example.org
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=org

# phpLDAPadmin Config
PHPLDAPADMIN_LDAP_HOSTS=ldap
PHPLDAPADMIN_HTTPS=false

# ==========================================
# Elasticsearch & Kibana Configuration
# ==========================================
# Go application configuration (maps via interpolation for config.go compatibility)
ES_ADDRESSES=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=${ELASTIC_PASSWORD}
ES_INDEX_NAME=users

# Elasticsearch configuration inside Docker Compose
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
