# ==========================================
# Application Config
# ==========================================
APP_ENV=development
LOG_LEVEL=info
DAEMON_MODE=true
SYNC_INTERVAL=1h

# ==========================================
# LDAP Configuration (OpenLDAP)
# ==========================================
LDAP_ORGANISATION=Example Org
LDAP_DOMAIN=example.org
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=org
LDAP_PASSWORD=admin
LDAP_BASE_DN=dc=example,dc=org

# LDAP Dynamic Query & Mapping
LDAP_ACTIVE_USER=(userPassword=*)
LDAP_FILTER=(&(objectClass=inetOrgPerson)({LDAP_ACTIVE_USER}))
LDAP_MAP_UID=uid
LDAP_MAP_USERNAME=cn
LDAP_MAP_EMAIL=mail

# ==========================================
# phpLDAPadmin Config
# ==========================================
PHPLDAPADMIN_LDAP_HOSTS=ldap
PHPLDAPADMIN_HTTPS=false

# ==========================================
# Elastic Stack Official Configuration
# ==========================================
ELASTIC_PASSWORD=adminpassword
KIBANA_SYSTEM_PASSWORD=${ELASTIC_PASSWORD}
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ==========================================
# Elasticsearch & Kibana Connection (Go Application)
# ==========================================
ES_ADDRESSES=http://localhost:9200
ES_USERNAME=elastic
ES_INDEX_NAME=users
ES_EXCLUDED_USERS=elastic,kibana_system,logstash_system,beats_system,apm_system,fleet_server_system
LDAP_SKIP_VERIFY=false
