# ==========================================================
# Groups & Role Mappings
# ==========================================================

# 1. Admin Group
dn: cn=app_admin,ou=groups,dc=example,dc=org
objectClass: groupOfUniqueNames
cn: app_admin
uniqueMember: uid=john.doe,ou=users,dc=example,dc=org
uniqueMember: uid=bob.brown,ou=users,dc=example,dc=org

# 2. User Group
dn: cn=app_user,ou=groups,dc=example,dc=org
objectClass: groupOfUniqueNames
cn: app_user
uniqueMember: uid=jane.smith,ou=users,dc=example,dc=org
uniqueMember: uid=alice.jones,ou=users,dc=example,dc=org
uniqueMember: uid=charlie.green,ou=users,dc=example,dc=org
uniqueMember: uid=david.white,ou=users,dc=example,dc=org
uniqueMember: uid=eva.black,ou=users,dc=example,dc=org

# 3. ReadOnly Group
dn: cn=app_readonly,ou=groups,dc=example,dc=org
objectClass: groupOfUniqueNames
cn: app_readonly
uniqueMember: uid=frank.grey,ou=users,dc=example,dc=org
uniqueMember: uid=grace.silver,ou=users,dc=example,dc=org
uniqueMember: uid=henry.gold,ou=users,dc=example,dc=org
uniqueMember: uid=user.crypt2a,ou=users,dc=example,dc=org
uniqueMember: uid=user.crypt2b,ou=users,dc=example,dc=org
uniqueMember: uid=user.ssha,ou=users,dc=example,dc=org
uniqueMember: uid=user.sha,ou=users,dc=example,dc=org
