groups:
  - name: ldap-es-syncer-alerts-test
    rules:
      # Alert if the sync job fails (sync success status is 0)
      - alert: SyncJobFailed
        expr: ldap_es_syncer_sync_success == 0
        for: 0s
        labels:
          severity: critical
        annotations:
          summary: "LDAP to ES Syncer execution failed (TEST)"
          description: "The last user synchronization run failed. (Immediate trigger for testing)"

      # Alert if active users count drops to 0 (potential LDAP query issue or empty directory)
      - alert: SyncNoActiveUsers
        expr: ldap_es_syncer_active_users == 0
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "No active users synced from LDAP (TEST)"
          description: "The number of active users synchronized is 0. (1-minute trigger for testing)"

      # Alert if no push to Pushgateway has occurred for more than 2 minutes (for batch mode / interval monitoring)
      - alert: SyncJobStale
        expr: time() - push_time_seconds{job="ldap_es_syncer"} > 120
        for: 10s
        labels:
          severity: critical
        annotations:
          summary: "Synchronization metrics are stale (TEST)"
          description: "No metrics have been pushed to Pushgateway for job 'ldap_es_syncer' in the last 2 minutes. (2-minute trigger for testing)"
